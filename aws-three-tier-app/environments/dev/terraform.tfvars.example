# Copy to terraform.tfvars and fill in real values (terraform.tfvars is gitignored).
# Get vpc_id / subnet ids from the aws-terraform-foundation outputs, or your own VPC.

region             = "us-east-1"
vpc_id             = "vpc-xxxxxxxx"
public_subnet_ids  = ["subnet-aaaa", "subnet-bbbb"]
private_subnet_ids = ["subnet-cccc", "subnet-dddd"]

instance_count        = 2
instance_profile_name = "" # e.g. "dev-ec2-baseline" from the foundation IAM module

# Never commit the real password. Prefer: export TF_VAR_db_password=...
db_password = "change-me-strong-password"
db_multi_az = false
